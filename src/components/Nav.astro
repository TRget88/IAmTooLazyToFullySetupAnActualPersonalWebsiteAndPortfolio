---
import { site } from '../config';

const path = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand">
      <svg
        class="brand-mark"
        width="22"
        height="22"
        viewBox="0 0 40 40"
        aria-hidden="true"
        focusable="false"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line x1="21" y1="10" x2="21" y2="30" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
        <line x1="21" y1="20" x2="32" y2="9" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
        <line x1="21" y1="20" x2="32" y2="31" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
        <line x1="18" y1="10" x2="8" y2="10" stroke="#5b8cf5" stroke-width="1.2" />
        <line x1="18" y1="30" x2="8" y2="30" stroke="#5b8cf5" stroke-width="1.2" />
        <line x1="11" y1="11" x2="11" y2="29" stroke="#5b8cf5" stroke-width="1.2" />
        <path d="M11 9.4 L9.2 13 L12.8 13 Z" fill="#5b8cf5" />
        <path d="M11 30.6 L9.2 27 L12.8 27 Z" fill="#5b8cf5" />
      </svg>
      <span>{site.name}</span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      {
        links.map((l) => (
          <a href={l.href} class:list={['nav-link', { active: isActive(l.href) }]}>
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
